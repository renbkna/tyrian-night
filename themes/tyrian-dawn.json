  "semanticTokenColors": {
    "*.declaration": {
      "bold": true
    },
    "parameter": {
      "foreground": "#904878",
      "italic": true
    },
    "variable.local": {
      "foreground": "#1E1828"
    },
    "variable.defaultLibrary": {
      "foreground": "#906818",
      "bold": true
    },
    "variable.readonly": {
      "foreground": "#906818"
    },
    "property.readonly": {
      "foreground": "#906818"
    },
    "function": {
      "foreground": "#1A7A70",
      "italic": true
    },
    "function.defaultLibrary": {
      "foreground": "#1A7A70"
    },
    "method": {
      "foreground": "#1A7A70",
      "italic": true
    },
    "class": {
      "foreground": "#4060A8"
    },
    "class.defaultLibrary": {
      "foreground": "#4060A8"
    },
    "interface": {
      "foreground": "#4060A8"
    },
    "type": {
      "foreground": "#4060A8"
    },
    "typeParameter": {
      "foreground": "#4060A8",
      "italic": true
    },
    "namespace": {
      "foreground": "#7050A0"
    },
    "enum": {
      "foreground": "#4060A8"
    },
    "enumMember": {
      "foreground": "#906818"
    },
    "property": {
      "foreground": "#1E1828"
    },
    "decorator": {
      "foreground": "#906818",
      "italic": true
    },
    "macro": {
      "foreground": "#906818"
    },
    "regexp": {
      "foreground": "#904878"
    }
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#72698C",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "comment.block.documentation",
      "settings": {
        "foreground": "#6B638A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.template", "punctuation.definition.string"],
      "settings": {
        "foreground": "#307048"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator",
        "entity.name.tag",
        "entity.name.tag.js",
        "entity.name.tag.css",
        "meta.import",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#7050A0"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "keyword.other.unit",
        "variable.other.enummember",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#906818"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.type.interface",
        "entity.name.type.class",
        "support.type",
        "support.class",
        "support.class.component",
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#4060A8"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "entity.name.method",
        "support.type.property-name.css",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#1A7A70",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable", "support.constant.property-value.css"],
      "settings": {
        "foreground": "#1E1828"
      }
    },
    {
      "scope": ["storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#7050A0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter", "meta.parameter", "entity.other.attribute-name"],
      "settings": {
        "foreground": "#904878",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string.regexp", "constant.character.escape"],
      "settings": {
        "foreground": "#904878"
      }
    },
    {
      "scope": ["variable.language", "entity.name.function.decorator"],
      "settings": {
        "foreground": "#906818",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "meta.decorator",
        "punctuation.decorator",
        "markup.list"
      ],
      "settings": {
        "foreground": "#906818"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#726892"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "foreground": "#7050A0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "foreground": "#1E1828",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "foreground": "#904878",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#1A7A70"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#4060A8"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#307048",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#B04848"
      }
    },
    {
      "scope": "invalid.deprecated",
      "settings": {
        "foreground": "#906818",
        "fontStyle": "strikethrough"
      }
    }
  ]
}
