  "semanticTokenColors": {
    "*.declaration": {
      "bold": true
    },
    "parameter": {
      "foreground": "#B878AA",
      "italic": true
    },
    "variable.local": {
      "foreground": "#D0C8E0"
    },
    "variable.defaultLibrary": {
      "foreground": "#C99F5A",
      "bold": true
    },
    "variable.readonly": {
      "foreground": "#C99F5A"
    },
    "property.readonly": {
      "foreground": "#C99F5A"
    },
    "function": {
      "foreground": "#3FA49D",
      "italic": true
    },
    "function.defaultLibrary": {
      "foreground": "#3FA49D"
    },
    "method": {
      "foreground": "#3FA49D",
      "italic": true
    },
    "class": {
      "foreground": "#6A85C6"
    },
    "class.defaultLibrary": {
      "foreground": "#6A85C6"
    },
    "interface": {
      "foreground": "#6A85C6"
    },
    "type": {
      "foreground": "#6A85C6"
    },
    "typeParameter": {
      "foreground": "#6A85C6",
      "italic": true
    },
    "namespace": {
      "foreground": "#9678C3"
    },
    "enum": {
      "foreground": "#6A85C6"
    },
    "enumMember": {
      "foreground": "#C99F5A"
    },
    "property": {
      "foreground": "#D0C8E0"
    },
    "decorator": {
      "foreground": "#C99F5A",
      "italic": true
    },
    "macro": {
      "foreground": "#C99F5A"
    },
    "regexp": {
      "foreground": "#B878AA"
    }
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#858DA9",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "comment.block.documentation",
      "settings": {
        "foreground": "#8890B0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.template", "punctuation.definition.string"],
      "settings": {
        "foreground": "#4F9E69"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator",
        "entity.name.tag",
        "entity.name.tag.js",
        "entity.name.tag.css",
        "meta.import",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#9678C3"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "keyword.other.unit",
        "variable.other.enummember",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#C99F5A"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.type.interface",
        "entity.name.type.class",
        "support.type",
        "support.class",
        "support.class.component",
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#6A85C6"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "entity.name.method",
        "support.type.property-name.css",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#3FA49D",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable", "support.constant.property-value.css"],
      "settings": {
        "foreground": "#D0C8E0"
      }
    },
    {
      "scope": ["storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#9678C3",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter", "meta.parameter", "entity.other.attribute-name"],
      "settings": {
        "foreground": "#B878AA",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string.regexp", "constant.character.escape"],
      "settings": {
        "foreground": "#B878AA"
      }
    },
    {
      "scope": ["variable.language", "entity.name.function.decorator"],
      "settings": {
        "foreground": "#C99F5A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "meta.decorator",
        "punctuation.decorator",
        "markup.list"
      ],
      "settings": {
        "foreground": "#C99F5A"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#8982A0"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "foreground": "#9678C3",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "foreground": "#D0C8E0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "foreground": "#B878AA",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#3FA49D"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#6A85C6"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#4F9E69",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#C26D6D"
      }
    },
    {
      "scope": "invalid.deprecated",
      "settings": {
        "foreground": "#C99F5A",
        "fontStyle": "strikethrough"
      }
    }
  ]
}
